{
  "name": "pillbox-mcp",
  "version": "0.1.2",
  "description": "MCP server for Pillbox — persistent memory for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --noEmit && esbuild src/index.ts --bundle --minify --platform=node --target=node20 --format=esm --outfile=dist/index.js",
    "dev": "node --watch dist/index.js",
    "typecheck": "tsc --noEmit",
    "fmt": "prettier --write \"src/**/*.ts\"",
    "fmt:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/node": "^22.14.1",
    "prettier": "^3.5.3",
    "esbuild": "^0.25.0"
  },
  "engines": {
    "node": ">=20"
  }
}
